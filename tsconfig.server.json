{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist-server",
    "rootDir": ".",
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "declaration": false,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts", "shared/**/*.ts", "types.ts"]
}
