# Firebase Web SDK config (FE)
# Per ADR-0001: these are PUBLIC values. Access control is enforced by
# Firestore security rules + Cloud Run IAM (server-side ID Token verification),
# not by keeping these secret.
#
# Where to find these: Firebase Console → Project Settings → General → Your apps
# (Web app) → SDK setup and configuration → Config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Local Auth Emulator: set to true to run with `npm run dev:emu`
# (auto-set by the script; you usually don't need to touch this manually)
VITE_USE_AUTH_EMULATOR=false
