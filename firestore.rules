rules_version = '2';

// users コレクション暫定運用。usage 等を追加する際は keys allowlist を再点検すること。
// Admin SDK 経由の `/api/users/init` はこのルールを bypass するため、route 側でも
// keys allowlist + 型/enum 検証を二重化している（rules/production-data-safety.md §3）。
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // M7-α (P4) で termsAcceptedAt / termsVersion を追加。
      // create 時は両者 null (= 未同意)、accept-terms route が update で server timestamp +
      // 現行 TERMS_VERSION を書込む。
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['email', 'plan', 'createdAt', 'updatedAt', 'termsAcceptedAt', 'termsVersion'])
        && request.resource.data.keys().hasAll(['email', 'plan', 'createdAt', 'updatedAt', 'termsAcceptedAt', 'termsVersion'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.plan in ['free']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.termsAcceptedAt == null
        && request.resource.data.termsVersion == null;

      // update の許可フィールド: email/plan/updatedAt は users/init 経路、
      // termsAcceptedAt/termsVersion は accept-terms 経路。createdAt 改ざんは引き続き拒否。
      // termsAcceptedAt は timestamp (server timestamp) または null、
      // termsVersion は 'YYYY-MM-DD' 形式の string または null。
      // 「片方同意・もう片方 null」の半端状態は禁止 (両方同時設定 or 両方 null のみ許可)。
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['email', 'plan', 'createdAt', 'updatedAt', 'termsAcceptedAt', 'termsVersion'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.plan in ['free']
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (request.resource.data.termsAcceptedAt == null && request.resource.data.termsVersion == null)
          ||
          (
            request.resource.data.termsAcceptedAt is timestamp
            && request.resource.data.termsVersion is string
            && request.resource.data.termsVersion.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          )
        );

      allow delete: if false;
    }

    // usage/{uidYyyymm}: AI 月間利用量カウンタ。
    // Admin SDK (server/services/usageService.ts) の transaction 経由のみ書込み、
    // client は read/write 共に全拒否。
    //
    // 将来 client が自 uid の usedCost を残量バー表示に使う場合は、uid と yyyymm を
    // path segment で分離した `usage/{uid}/months/{yyyymm}` 形に変更し
    // `request.auth.uid == uid` で exact match することを推奨。
    // 単一 docId に regex を直接かける `uidYyyymm.matches(...)` 形式は uid の文字種前提に
    // 安全性が依存するため避ける（Codex review 指摘）。
    match /usage/{uidYyyymm} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
